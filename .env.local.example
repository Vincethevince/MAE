# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email (Resend - https://resend.com)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# The "from" address for all outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=MAE <noreply@your-domain.com>

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Service Role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cron secret (set the same value in Vercel env vars)
CRON_SECRET=generate-a-random-secret-here
